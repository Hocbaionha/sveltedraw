# Puppeteer smoke-test artifacts (visual baselines, PDF exports, etc.)
# Tests generate these alongside their assertions; they're not source-of-truth.
/test-*.pdf
/test-*.png
/*.png
/packages/excalidraw-svelte/*.png
/packages/excalidraw-svelte/*.pdf
/sveltedraw-app/*.png
/sveltedraw-app/*.pdf

# Honest-test result dumps + ad-hoc subprocess captures. These are
# non-reproducible byproducts of one-off runs; keep the runner and
# the assertion logic, not the JSON output.
/test-*-results.json
/test-results.json
/yws-*.txt
/yws-*.log
