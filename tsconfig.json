{
  "compilerOptions": {
    "rootDir": "./",
    "target": "ESNext",
    "lib": ["dom", "dom.iterable", "esnext"],
    "types": ["vitest/globals", "@testing-library/jest-dom"],
    "allowJs": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "noFallthroughCasesInSwitch": true,
    "module": "ESNext",
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "baseUrl": ".",
    "paths": {
      "@sveltedraw/common": ["./packages/common/src/index.ts"],
      "@sveltedraw/common/*": ["./packages/common/src/*"],
      "@sveltedraw/engine": ["./packages/excalidraw/index.tsx"],
      "@sveltedraw/engine/*": ["./packages/excalidraw/*"],
      "@sveltedraw/element": ["./packages/element/src/index.ts"],
      "@sveltedraw/element/*": ["./packages/element/src/*"],
      "@sveltedraw/math": ["./packages/math/src/index.ts"],
      "@sveltedraw/math/*": ["./packages/math/src/*"],
      "@sveltedraw/utils": ["./packages/utils/src/index.ts"],
      "@sveltedraw/utils/*": ["./packages/utils/src/*"]
    }
  },
  "include": ["packages", "excalidraw-app"],
  "exclude": [
    "examples",
    "dist",
    "types",
    "tests",
    "packages/excalidraw-svelte"
  ]
}
