{
  "compilerOptions": {
    "target": "ESNext",
    "strict": true,
    "skipLibCheck": true,
    "declaration": true,
    "allowSyntheticDefaultImports": true,
    "module": "ESNext",
    "moduleResolution": "Node",
    "resolveJsonModule": true,
    "jsx": "react-jsx",
    "emitDeclarationOnly": true,
    "paths": {
      "@sveltedraw/common": ["./common/src/index.ts"],
      "@sveltedraw/common/*": ["./common/src/*"],
      "@sveltedraw/element": ["./element/src/index.ts"],
      "@sveltedraw/element/*": ["./element/src/*"],
      "@sveltedraw/engine": ["./excalidraw/index.tsx"],
      "@sveltedraw/engine/*": ["./excalidraw/*"],
      "@sveltedraw/math": ["./math/src/index.ts"],
      "@sveltedraw/math/*": ["./math/src/*"],
      "@sveltedraw/utils": ["./utils/src/index.ts"],
      "@sveltedraw/utils/*": ["./utils/src/*"]
    }
  }
}
