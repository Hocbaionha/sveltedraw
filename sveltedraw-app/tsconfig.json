{
  "compilerOptions": {
    "target": "ESNext",
    "useDefineForClassFields": true,
    "module": "ESNext",
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "isolatedModules": true,
    "moduleDetection": "force",
    "noEmit": true,
    "strict": true,
    "skipLibCheck": true,
    "verbatimModuleSyntax": true,
    "paths": {
      "@sveltedraw/editor": ["../packages/editor/src/index.ts"],
      "@sveltedraw/common": ["../packages/common/src/index.ts"],
      "@sveltedraw/common/*": ["../packages/common/src/*"],
      "@sveltedraw/element": ["../packages/element/src/index.ts"],
      "@sveltedraw/element/*": ["../packages/element/src/*"],
      "@sveltedraw/math": ["../packages/math/src/index.ts"],
      "@sveltedraw/math/*": ["../packages/math/src/*"],
      "@sveltedraw/utils": ["../packages/utils/src/index.ts"],
      "@sveltedraw/utils/*": ["../packages/utils/src/*"]
      // The core TS packages (common/element/math/utils) are pure
      // TypeScript and safe to path-map. `@sveltedraw/engine` has NO
      // path mapping because many of its files have internal type
      // errors we haven't audited; they aren't in our runtime path so
      // svelte-check catching them would only produce noise. Runtime
      // resolution of `@sveltedraw/engine/*` is handled by Vite
      // aliases (vite.config.ts).
    }
  },
  "include": ["src/**/*", "../packages/editor/src/**/*"],
  "exclude": [
    "node_modules",
    "dist",
    "../packages/engine/**",
    "../packages/common/**",
    "../packages/element/**",
    "../packages/math/**",
    "../packages/utils/**"
  ]
}
